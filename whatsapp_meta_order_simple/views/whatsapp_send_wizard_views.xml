<?xml version="1.0" encoding="utf-8"?>
<!--
    Vista del wizard whatsapp.send.wizard.

    Formulario modal con:
    - Cuenta (readonly)
    - Template a enviar
    - Opción "Enviar sin parámetros" (para templates sin variables)
    - Lista de pedidos destino
    - Botón Enviar / Cancelar
-->
<odoo>
    <record id="view_whatsapp_send_wizard_form" model="ir.ui.view">
        <field name="name">whatsapp.send.wizard.form</field>
        <field name="model">whatsapp.send.wizard</field>
        <field name="arch" type="xml">
            <form string="Enviar WhatsApp">
                <group>
                    <field name="account_id"/>
                    <field name="allow_test_templates"/>
                    <field name="allowed_template_ids" invisible="1"/>
                    <field name="template_id"/>
                    <field name="send_without_parameters"/>
                    <field name="sale_order_ids" widget="many2many_tags"/>
                </group>
                <footer>
                    <button
                        name="action_confirm_send"
                        type="object"
                        string="Enviar"
                        class="btn-primary"
                    />
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
