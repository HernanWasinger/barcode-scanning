<?xml version="1.0" encoding="utf-8"?>
<!--
    Vista del wizard whatsapp.test.send.wizard.

    Formulario modal para pruebas (sin vincular a pedidos):
    - Cuenta (readonly)
    - Contacto opcional (autocompleta teléfono)
    - Teléfono destino
    - Template (solo los que no requieren parámetros)
    - Botón Enviar / Cancelar
-->
<odoo>
    <record id="view_whatsapp_test_send_wizard_form" model="ir.ui.view">
        <field name="name">whatsapp.test.send.wizard.form</field>
        <field name="model">whatsapp.test.send.wizard</field>
        <field name="arch" type="xml">
            <form string="Enviar prueba WhatsApp">
                <group>
                    <field name="account_id"/>
                    <field name="partner_id"/>
                    <field name="to_phone"/>
                    <field name="allow_test_templates"/>
                    <field name="allowed_template_ids" invisible="1"/>
                    <field name="template_id"/>
                </group>
                <footer>
                    <button
                        name="action_send_test"
                        type="object"
                        string="Enviar"
                        class="btn-primary"
                    />
                    <button string="Cancelar" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
